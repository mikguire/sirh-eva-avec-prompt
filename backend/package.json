{
  "name": "eva-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:cov": "jest --coverage",
    "db:check": "node scripts/check-db-access.cjs",
    "test:integration:prepare": "sh -c 'export DATABASE_URL=\"${INTEGRATION_DATABASE_URL:-postgresql://postgres:postgres@127.0.0.1:5432/eva_test}\"; npm run db:check && npm run prisma:migrate:deploy && npm run prisma:seed'",
    "test:integration": "npm run test:integration:prepare && jest --config jest.integration.config.cjs --runInBand",
    "test:int": "npm run test:integration",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "worker:notifications": "ts-node src/workers/notifications.worker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.901.0",
    "@aws-sdk/s3-request-presigner": "^3.901.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "6.13.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.58.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.3",
    "@types/supertest": "^6.0.2",
    "@types/passport-jwt": "^4.0.1",
    "dotenv": "^16.4.7",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "prisma": "6.13.0",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
