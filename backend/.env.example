# Docker Compose : par défaut port hôte 5432 ; si occupé → EVA_POSTGRES_PORT=5433 à la racine puis `:5433` ici.
# Identifiants à aligner avec docker-compose (EVA_POSTGRES_USER / EVA_POSTGRES_PASSWORD / EVA_POSTGRES_DB).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eva_test"
# Optionnel : URL dédiée aux tests d'intégration (`npm run test:integration`). Si absent, la suite utilise postgres/postgres@127.0.0.1:5432/eva_test quelle que soit DATABASE_URL ci-dessus.
# Important : aligner host/port/user/password avec les variables EVA_POSTGRES_* utilisées par docker compose.
# INTEGRATION_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/eva_test"
# Derrière reverse-proxy (Nginx, Traefik, load balancer) : "true" ou "1" pour que l’IP client et le throttling Throttler utilisent X-Forwarded-For (Express trust proxy).
TRUST_PROXY="false"
# En production (NODE_ENV=production), min. 32 caractères chacun — obligatoires au démarrage.
JWT_ACCESS_SECRET="replace_me_access_at_least_32_chars______"
JWT_REFRESH_SECRET="replace_me_refresh_at_least_32_chars____"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
S3_BUCKET="eva-documents"
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID="replace_me"
AWS_SECRET_ACCESS_KEY="replace_me"
S3_ENDPOINT=""
S3_FORCE_PATH_STYLE="false"
REDIS_URL="redis://localhost:6379"
